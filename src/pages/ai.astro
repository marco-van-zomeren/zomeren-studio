---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="AI | zomeren.studio"
  description="AI-driven creative exploration across design, prototyping, image, video and music."
  lang="en"
  enPath="/ai/"
  nlPath="/nl/ai/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"AI | zomeren.studio","description":"AI-driven creative exploration across design, prototyping, image, video and music.","url":"https://zomeren.studio/ai/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/ai/" nlHref="/nl/ai/" lang="en" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Always on the forefront of AI, design and innovation.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img
            src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp"
            alt="Mindstone AI visual"
            class="aspect-[2/3] w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(2rem,2.05vw,3rem)] leading-[1.22] tracking-[-0.015em]">
            I&rsquo;m always pushing at the edges of AI, design, and innovation, constantly exploring new possibilities and learning everything this evolving field can offer. From image and video generation to rapid prototyping and even music creation, I dive deep into the tools that shape the next wave of creativity. For me, AI isn&rsquo;t just a workflow upgrade, it&rsquo;s a space where intuition, experimentation, and vision meet, opening new ways to express ideas with presence and resonance.
          </p>

          <p class="mt-12 md:mt-16">
            <a href="/contact/" class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]">
              <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Let&rsquo;s work
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
