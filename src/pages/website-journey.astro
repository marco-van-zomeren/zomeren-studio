---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ShitDoneCtaSection from '../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="Website Journey | zomeren.studio"
  description="A four-step website journey covering discovery, wireframes, visual design, motion and final handoff."
  lang="en"
  enPath="/website-journey/"
  nlPath="/nl/website-journey/"
  ogImage="https://zomeren.studio/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Website Journey | zomeren.studio","description":"A four-step website journey covering discovery, wireframes, visual design, motion and final handoff.","url":"https://zomeren.studio/website-journey/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/website-journey/" nlHref="/nl/website-journey/" lang="en" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        A website journey where strategy, design, and delivery flow seamlessly into one another.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img src="/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp" alt="Website journey visual"
            class="aspect-[2/3] w-full object-cover" loading="eager" decoding="async" />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            A strong website project starts long before pixels move. It begins with understanding the request, the market,
            the competitors, the amount of pages, the technical reality, and the scope needed to make the work useful.
          </p>
          <p class="mt-6 text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            This website journey follows four practical phases: earth, air, fire, and water. Each phase moves the process
            forward with a different purpose, from discovery and wireframes to visual design, motion, feedback, and final
            handoff.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="py-8 md:py-12">
      <div class="space-y-12 md:space-y-16">
        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/earth.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">1 Structure</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Discovery, scope, and foundation</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              We start with a working session to understand the request in full: business goals, audience, market, competitors,
              content needs, amount of pages, timeline, and technical context. This phase defines the scope and creates the
              structure needed to make decisions with clarity instead of guesswork.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/air.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">2 Strategy</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Concept, sitemap, and wireframes</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Once the foundation is set, we shape the first concept. That usually means a sitemap, content hierarchy,
              wireframes, and an initial visual direction for the website. It is the phase where logic meets feeling, and where
              the first feedback round sharpens the route before design is pushed further.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/fire.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">3 Vision</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Visual design, motion, and interaction</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Here the website gets its full visual force. We design the most important templates and pages in detail, define
              components, interaction states, and motion principles, and explore how transitions and animations can add rhythm
              without getting in the way of usability. This is where the concept becomes unmistakably alive.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/water.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">4 Delivery</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Presentation, refinement, and handoff</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              The final phase is about alignment and delivery. We present the complete visual design, walk through the experience,
              discuss impact and emotion, process the last feedback round, and prepare the handoff. Deliverables can include
              design files, a style guide, motion references, exported assets, and the structure needed for development.
            </p>
          </div>
        </article>
      </div>
    </section>

    <ShitDoneCtaSection />
  </main>
  <Footer />
</BaseLayout>
