                </figure>
                <h2 class="mt-4 text-[clamp(1.6rem,2vw,2.6rem)] leading-[1.1] tracking-[-0.015em]">Avance</h2>
                <div class="mt-5"><span class="inline-flex rounded-full border border-black/55 px-6 py-2 leading-none tracking-[-0.01em] dark:border-white/55">2019</span></div>
              </div>
            </article>
            <article class="swiper-slide">
              <div class="music-release-card pb-8">
