                  </a>
                </figure>
                <h2 class="mt-4 text-[clamp(1.6rem,2vw,2.6rem)] leading-[1.1] tracking-[-0.015em]">Systole</h2>
                <div class="mt-5"><span class="inline-flex rounded-full border border-black/55 px-6 py-2 leading-none tracking-[-0.01em] dark:border-white/55">2019</span></div>
              </div>
            </article>
            <article class="swiper-slide">
              <div class="music-release-card pb-8">
                <figure class="relative">
                  <img src="/assets/images/music/misere.jpeg" alt="Misere cover" class="aspect-square w-full object-cover" loading="lazy" decoding="async" />
                  <a href="https://open.spotify.com/search/marco%20van%20zomeren%20misere" target="_blank" rel="noreferrer noopener" aria-label="Play release on Spotify" class="absolute left-1/2 top-1/2 z-20 inline-flex h-20 w-20 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white text-black shadow-[0_0_0_1px_rgba(255,255,255,0.35)]">
                    <span class="material-symbols-outlined music-play-icon text-[2.6rem] leading-none">play_arrow</span>
