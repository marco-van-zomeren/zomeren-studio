---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Motion | zomeren.studio"
  description="Motion design that turns brand essence into movement, rhythm and resonance."
  lang="en"
  enPath="/motion/"
  nlPath="/nl/motion/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Motion | zomeren.studio","description":"Motion design that turns brand essence into movement, rhythm and resonance.","url":"https://zomeren.studio/motion/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/motion/" nlHref="/nl/motion/" lang="en" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        I translate the essence of a brand into motion and design that speaks, moves, and resonates.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <video class="aspect-[2/3] w-full object-cover" autoplay loop muted playsinline preload="metadata">
            <source src="/assets/video/work.webm" type="video/webm" />
          </video>
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(2rem,2.05vw,3rem)] leading-[1.22] tracking-[-0.015em]">
            Through motion design, I turn a client&rsquo;s essence into moving brand experiences, syncing visual identity and energy with the flow that&rsquo;s already in motion. It&rsquo;s design with presence, resonance, and the magic when strategy meets soul.
          </p>

          <p class="mt-12 md:mt-16">
            <a href="/contact/" class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]">
              <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Let&rsquo;s work
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
