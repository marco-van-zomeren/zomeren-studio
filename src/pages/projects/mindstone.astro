---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Mindstone | zomeren.studio"
  description="Mindstone branding case study by Marco van Zomeren for WADM."
  lang="en"
  enPath="/projects/mindstone/"
  nlPath="/nl/projects/mindstone/"
  ogImage="https://zomeren.studio/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp"
  bodyClass="project-page"
  schema={`{"@context":"https://schema.org","@type":"CreativeWork","name":"Mindstone | zomeren.studio","description":"Mindstone branding case study by Marco van Zomeren for WADM.","url":"https://zomeren.studio/projects/mindstone/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/projects/mindstone/" nlHref="/nl/projects/mindstone/" lang="en" />
  <main class="pb-24 md:pb-36">
    <section data-reveal>
      <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp" alt="Mindstone cover" class="project-featured-image aspect-[16/9] w-full object-cover" />
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="grid w-full grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-5">
          <h1 class="text-[clamp(2rem,5.4vw,5.2rem)] leading-[0.97] tracking-[-0.02em]">Mindstone</h1>
          <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-6 text-[clamp(1rem,1.5vw,2rem)] leading-[1.1] tracking-[-0.01em]">
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">What</p>
            <p>Brand Identity</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Where</p>
            <p>WADM</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Role</p>
            <p>Senior Brand / Visual Designer</p>
          </div>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em]">
            Mindstone is a strategic employer branding project built to communicate confidence, structure, and long-term growth.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="space-y-6 md:space-y-8">
        <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762721536/mindstone_colors_czww5s.mp4" type="video/mp4" />
        </video>
        <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762721536/mindstone_concept_shapes_ieqqll.mp4" type="video/mp4" />
        </video>
        <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762721536/mindstone_shapes_zk4f7j.mp4" type="video/mp4" />
        </video>
        <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762721536/mindstone_logo_g1j9ha.mp4" type="video/mp4" />
        </video>
        <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762721536/mindstone_bogen_gwhltc.mp4" type="video/mp4" />
        </video>
      </div>
    </section>

    <section data-reveal class="px-6 pt-16 md:px-12 md:pt-24">
      <div class="space-y-10 md:space-y-12">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Design</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            The identity positions Mindstone as a calm, knowledgeable partner. Not competing with HR, but strengthening them.
            Visual restraint, structured layouts and a grounded color palette reinforce trust, progress and long-term thinking.
            Shapes, grids and movement are inspired by milestones and continuous development - branding as a process, not a promise.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Result</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            The result is a composed and strategic brand system that reflects Mindstone's role: building sustainable employer brands
            and empowering organizations to own and grow them themselves.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="space-y-6 md:space-y-8">
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_2.webp" alt="Mindstone image 2" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_3.webp" alt="Mindstone image 3" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_4.webp" alt="Mindstone image 4" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_5.webp" alt="Mindstone image 5" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_6.webp" alt="Mindstone image 6" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_7.webp" alt="Mindstone image 7" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_8.webp" alt="Mindstone image 8" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_9.webp" alt="Mindstone image 9" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_10.webp" alt="Mindstone image 10" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_11.webp" alt="Mindstone image 11" class="w-full object-cover" />
        <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_12.webp" alt="Mindstone image 12" class="w-full object-cover" />
      </div>
    </section>

    <section data-reveal class="px-6 pt-20 md:px-12 md:pt-24">
      <p class="mb-6 text-[clamp(1.1rem,1vw,1.4rem)] uppercase tracking-[0.08em] text-black/75 dark:text-white/75">More posts</p>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10">
        <article>
          <a href="/projects/gearfreak/" class="block">
            <img src="/assets/images/projects/gearfreak/1_gearfreak_design-by-wadm.webp" alt="Gearfreak cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Gearfreak</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
        <article>
          <a href="/projects/keller/" class="block">
            <img src="/assets/images/projects/keller/1-keller-design-by-wadm.webp" alt="Keller cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Keller</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
