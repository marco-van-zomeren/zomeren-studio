---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Keller | zomeren.studio"
  description="Keller brand identity case study by Marco van Zomeren for WADM."
  lang="en"
  enPath="/projects/keller/"
  nlPath="/nl/projects/keller/"
  ogImage="https://zomeren.studio/assets/images/projects/keller/1-keller-design-by-wadm.webp"
  bodyClass="project-page"
  schema={`{"@context":"https://schema.org","@type":"CreativeWork","name":"Keller | zomeren.studio","description":"Keller brand identity case study by Marco van Zomeren for WADM.","url":"https://zomeren.studio/projects/keller/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/projects/keller/" nlHref="/nl/projects/keller/" lang="en" />
  <main class="pb-24 md:pb-36">
    <section data-reveal>
      <img src="/assets/images/projects/keller/1-keller-design-by-wadm.webp" alt="Keller cover" class="project-featured-image aspect-[16/9] w-full object-cover" />
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="grid w-full grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-5">
          <h1 class="text-[clamp(2rem,5.4vw,5.2rem)] leading-[0.97] tracking-[-0.02em]">Keller</h1>
          <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-6 text-[clamp(1rem,1.5vw,2rem)] leading-[1.1] tracking-[-0.01em]">
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">What</p>
            <p>Brand identity</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Where</p>
            <p>WADM</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Role</p>
            <p>Designer</p>
          </div>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em]">
            WADM helped keller infra level up from a traditional civil engineering brand to a bold challenger with a clear story. together we sharpened their positioning from execution to innovation and gave them the confidence to own a new space in the market. just dig it became more than a line; it&rsquo;s their mindset.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <video class="aspect-video w-full object-cover" autoplay loop muted playsinline preload="metadata">
        <source src="https://res.cloudinary.com/zomerenstudio/video/upload/v1762717353/Keller_-_Showreel_k0udj4.mp4" type="video/mp4" />
      </video>
    </section>

    <section data-reveal class="px-6 pt-16 md:px-12 md:pt-24">
      <div class="space-y-10 md:space-y-12">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Design</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            The new identity hits hard: raw, industrial energy meets clean design. we built a system that feels technical but never stiff &mdash; bold typography, sharp color contrasts and visual motion that mirrors their fieldwork. everything connects back to doing things differently, smarter and with purpose.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Result</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            Branding wasn&rsquo;t just a facelift &mdash; it&rsquo;s a full-on culture shift. every touchpoint, from pitch decks to helmets, reflects the same attitude and ambition. that&rsquo;s the power of thinking in systems, not silos: a story that runs through every layer of the brand, from ground to skyline.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="space-y-6 md:space-y-8">
        <img src="/assets/images/projects/keller/2_keller_design-by-wadm.webp" alt="Keller image 2" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/3-keller-design-by-wadm.webp" alt="Keller image 3" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/4-keller-design-by-wadm.webp" alt="Keller image 4" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/5-keller-design-by-wadm.webp" alt="Keller image 5" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/6-keller-design-by-wadm.webp" alt="Keller image 6" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/7-keller-design-by-wadm.webp" alt="Keller image 7" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/8-keller-design-by-wadm.webp" alt="Keller image 8" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/9-keller-design-by-wadm.webp" alt="Keller image 9" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/10-keller-design-by-wadm.webp" alt="Keller image 10" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/11-keller-design-by-wadm.webp" alt="Keller image 11" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/12-keller-design-by-wadm.webp" alt="Keller image 12" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/13-keller-design-by-wadm.webp" alt="Keller image 13" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/14-keller-design-by-wadm.webp" alt="Keller image 14" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/15-keller-design-by-wadm.webp" alt="Keller image 15" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/16-keller-design-by-wadm.webp" alt="Keller image 16" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/17-keller-design-by-wadm.webp" alt="Keller image 17" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/18-keller-design-by-wadm.webp" alt="Keller image 18" class="w-full object-cover" />
        <img src="/assets/images/projects/keller/19-keller-design-by-wadm.webp" alt="Keller image 19" class="w-full object-cover" />
      </div>
    </section>

    <section data-reveal class="px-6 pt-20 md:px-12 md:pt-24">
      <p class="mb-6 text-[clamp(1.1rem,1vw,1.4rem)] uppercase tracking-[0.08em] text-black/75 dark:text-white/75">More posts</p>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10">
        <article>
          <a href="/projects/gearfreak/" class="block">
            <img src="/assets/images/projects/gearfreak/1_gearfreak_design-by-wadm.webp" alt="Gearfreak cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Gearfreak</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
        <article>
          <a href="/projects/mindstone/" class="block">
            <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp" alt="Mindstone cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Mindstone</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
