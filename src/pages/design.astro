---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Design | zomeren.studio"
  description="Explore branding, motion, UI/UX and AI expertise at zomeren.studio."
  lang="en"
  enPath="/design/"
  nlPath="/nl/design/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Design | zomeren.studio","description":"Explore branding, motion, UI/UX and AI expertise at zomeren.studio.","url":"https://zomeren.studio/design/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/design/" nlHref="/nl/design/" lang="en" />
  <main class="px-6 pb-24 pt-24 md:px-12 md:pb-36 md:pt-28">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Let the sun shine on your brand, website, campaign, or anything you can imagine.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">04</p>
        </div>

        <div class="relative col-span-4 lg:col-span-8">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">Skills</p>
          <p class="m-0 max-w-[24ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            Expertises which are making brands resonate with their highest potential
          </p>
        </div>
      </div>

      <div class="mt-16 space-y-2 md:mt-20 md:space-y-3">
        <a href="/branding/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">01</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">Branding</span>
        </a>
        <a href="/motion/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">02</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">Motion</span>
        </a>
        <a href="/ui-ux/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">03</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">UI/UX</span>
        </a>
        <a href="/ai/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">04</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">AI</span>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
