---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
---
<BaseLayout
  title="Astrologie | zomeren.studio"
  description="Ontdek sterrenbeelden, elementen en symbolische betekenissen via een helder astrologisch overzicht."
  lang="nl"
  enPath="/astrology/"
  nlPath="/nl/astrology/"
  schema={`{"@context":"https://schema.org","@type":"CollectionPage","name":"Astrologie | zomeren.studio","description":"Ontdek sterrenbeelden, elementen en symbolische betekenissen via een helder astrologisch overzicht.","url":"https://zomeren.studio/nl/astrology/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/astrology/" nlHref="/nl/astrology/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Astrologie geeft taal aan persoonlijkheid, timing en richting.
      </h1>
    </section>

    <section data-reveal class="py-8 md:py-12" data-zodiac-filter-root>
      <p class="max-w-[48ch] text-[clamp(2rem,2.05vw,3rem)] leading-[1.22] tracking-[-0.015em] text-black/90 dark:text-white/90">
        Een beknopt zodiac-overzicht op basis van klassieke astrologische betekenissen: elk teken heeft een eigen stijl,
        drijfveer en manier van ervaren.
      </p>

      <div class="mt-10 flex flex-wrap gap-3 md:gap-4" data-zodiac-filters>
        <button type="button" data-filter="earth"
          class="rounded-full border border-black/40 dark:border-white/40 px-6 py-3 text-[clamp(1rem,1.1vw,1.3rem)] leading-none tracking-[0.02em] uppercase">Aarde</button>
        <button type="button" data-filter="air"
          class="rounded-full border border-black/40 dark:border-white/40 px-6 py-3 text-[clamp(1rem,1.1vw,1.3rem)] leading-none tracking-[0.02em] uppercase">Lucht</button>
        <button type="button" data-filter="fire"
          class="rounded-full border border-black/40 dark:border-white/40 px-6 py-3 text-[clamp(1rem,1.1vw,1.3rem)] leading-none tracking-[0.02em] uppercase">Vuur</button>
        <button type="button" data-filter="water"
          class="rounded-full border border-black/40 dark:border-white/40 px-6 py-3 text-[clamp(1rem,1.1vw,1.3rem)] leading-none tracking-[0.02em] uppercase">Water</button>
        <button type="button" data-filter-reset aria-label="Reset zodiac filter"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-black/40 dark:border-white/40">
          <span class="material-symbols-outlined text-[1.4rem] leading-none">replay</span>
        </button>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3" data-zodiac-grid>
        <article data-element="fire" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/ram.svg" alt="Ram symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Ram</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Vuur</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Direct, initi&euml;rend en moedig. Ram beweegt als eerste, leert door te doen en brengt vaart waar het vastloopt.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/aries/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="earth" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/stier.svg" alt="Stier symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Stier</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Aarde</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Standvastig, zintuiglijk en praktisch. Stier bouwt zekerheid op de lange termijn en hecht aan kwaliteit en vertrouwen.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/taurus/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="air" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/tweelingen.svg" alt="Tweelingen symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Tweelingen</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Lucht</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Nieuwsgierig, flexibel en mentaal snel. Tweelingen verbinden idee&euml;n en mensen via taal, humor en perspectief.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/gemini/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="water" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/kreeft.svg" alt="Kreeft symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Kreeft</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Water</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Beschermend, intu&iuml;tief en gevoelig. Kreeft leest emoties feilloos en cre&euml;ert veiligheid en verbondenheid.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/cancer/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="fire" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/leeuw.svg" alt="Leeuw symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Leeuw</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Vuur</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Expressief, warm en creatief. Leeuw leidt vanuit het hart en groeit wanneer betekenis en zichtbaarheid samenkomen.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/leo/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="earth" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/maagd.svg" alt="Maagd symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Maagd</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Aarde</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Precies, analytisch en behulpzaam. Maagd verfijnt processen en maakt complexe dingen bruikbaar en helder.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/virgo/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="air" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/weegschaal.svg" alt="Weegschaal symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Weegschaal</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Lucht</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Relationeel, diplomatiek en esthetisch. Weegschaal zoekt balans, eerlijkheid en sterke samenwerking.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/libra/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="water" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/schorpioen.svg" alt="Schorpioen symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Schorpioen</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Water</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Intens, gefocust en transformerend. Schorpioen zoekt diepte, waarheid en emotionele echtheid.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/scorpio/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="fire" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/boogschutter.svg" alt="Boogschutter symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Boogschutter</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Vuur</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Visionair, ontdekkend en vrijheidsgericht. Boogschutter verruimt grenzen via ervaring, kennis en zingeving.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/sagittarius/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="earth" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/steenbok.svg" alt="Steenbok symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Steenbok</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Aarde</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Strategisch, gedisciplineerd en duurzaam. Steenbok bouwt aan langetermijnresultaat met verantwoordelijkheid.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/capricorn/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="air" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/waterman.svg" alt="Waterman symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Waterman</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Lucht</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Onafhankelijk, vernieuwend en toekomstgericht. Waterman denkt systemisch en durft conventies te doorbreken.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/aquarius/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>

        <article data-element="water" class="border-b border-black/25 dark:border-white/25 pb-8 pt-2 flex flex-col">
          <img src="/assets/svg/vissen.svg" alt="Vissen symbool" class="h-20 w-20 object-contain dark:invert" />
          <h2 class="mt-5 text-[2rem] leading-none tracking-[-0.02em]">Vissen</h2>
          <p class="mt-3 inline-flex w-fit self-start items-center rounded-full border border-black/45 dark:border-white/45 px-6 py-2 text-[0.75rem] uppercase tracking-[0.08em]">Water</p>
          <p class="mt-5 text-[clamp(1rem,1.2vw,1.4rem)] leading-[1.35] text-black/90 dark:text-white/90">Empathisch, verbeeldend en symbolisch. Vissen voelen nuances aan en vertalen emotie naar betekenis.</p>
          <p class="mt-6 w-fit self-start"><a data-zodiac-read-more href="/nl/astrology/pisces/" class="inline-flex w-fit items-center rounded-full bg-black px-6 py-3 text-[clamp(0.95rem,1vw,1.15rem)] leading-none tracking-[0.02em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85">Lees meer</a></p>
        </article>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
