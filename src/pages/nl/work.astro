---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
---
<BaseLayout
  title="Werk | zomeren.studio"
  description="Geselecteerde branding-, webdesign- en digitale cases van Marco van Zomeren met KR Communicatie en WADM."
  lang="nl"
  enPath="/work/"
  nlPath="/nl/work/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Werk | zomeren.studio","description":"Geselecteerde branding-, webdesign- en digitale cases van Marco van Zomeren met KR Communicatie en WADM.","url":"https://zomeren.studio/nl/work/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/work/" nlHref="/nl/work/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal>
      <h1 class="max-w-[24ch] text-[clamp(2.4rem,5vw,7rem)] leading-[1.02] tracking-[-0.024em] font-[700]">
        Werk dat sterke designfundamenten verbindt met de vloeiendheid van motion graphics.
      </h1>
      <p class="mt-12 max-w-[18ch] text-[clamp(1.9rem,2.7vw,3.4rem)] leading-[1.05] tracking-[-0.015em] text-black/92 dark:text-white/92">
        Cases uit 2022 / 2025, gemaakt bij WADM.
      </p>
    </section>

    <section data-reveal class="pt-16 md:pt-20">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8">
        <article data-reveal>
          <a href="/nl/projects/mindstone/" class="block">
            <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp" alt="Mindstone cover" class="aspect-[4/5] w-full object-cover" />
          </a>
        </article>
        <article data-reveal>
          <a href="/nl/projects/gearfreak/" class="block">
            <img src="/assets/images/projects/gearfreak/1_gearfreak_design-by-wadm.webp" alt="Gearfreak cover" class="aspect-[4/5] w-full object-cover" />
          </a>
        </article>
        <article data-reveal>
          <a href="/nl/projects/keller/" class="block">
            <img src="/assets/images/projects/keller/1-keller-design-by-wadm.webp" alt="Keller cover" class="aspect-[4/5] w-full object-cover" />
          </a>
        </article>
      </div>
    </section>

    <section data-reveal class="pt-10 md:pt-14">
      <div class="grid grid-cols-1 gap-x-8 gap-y-14 lg:grid-cols-3 md:gap-y-16">
        <article data-reveal>
          <a href="/nl/projects/medigo/" class="block">
            <img src="/assets/images/projects/medigo/1_medigo_design-by-wadm.webp" alt="Medigo cover" class="aspect-[4/5] w-full object-cover" />
            <h2 class="mt-5 text-[clamp(1.04rem,1.35vw,1.34rem)] leading-[1.2] tracking-[-0.008em]">Medigo</h2>
          </a>
        </article>
        <article data-reveal>
          <a href="/nl/projects/ultimo/" class="block">
            <img src="/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp" alt="Ultimo cover" class="aspect-[4/5] w-full object-cover" />
            <h2 class="mt-5 text-[clamp(1.04rem,1.35vw,1.34rem)] leading-[1.2] tracking-[-0.008em]">Ultimo</h2>
          </a>
        </article>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
