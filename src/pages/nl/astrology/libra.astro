---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FooterNL from '../../../components/FooterNL.astro';
---
<BaseLayout
  title="Weegschaal | Astrologie | zomeren.studio"
  description="Weegschaal in astrologie: kernkwaliteiten, krachten, uitdagingen en symbolische betekenis."
  lang="nl"
  enPath="/astrology/libra/"
  nlPath="/nl/astrology/libra/"
  ogImage="https://zomeren.studio/assets/images/marco/marco_van_zomeren_studio.webp"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Weegschaal | Astrologie | zomeren.studio","description":"Weegschaal in astrologie: kernkwaliteiten, krachten, uitdagingen en symbolische betekenis.","url":"https://zomeren.studio/nl/astrology/libra/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/astrology/libra/" nlHref="/nl/astrology/libra/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">Weegschaal is een teken van het element Lucht, gevormd door instinct, timing en karakter.</h1>
    </section>
    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <div class="flex aspect-[2/3] w-full items-center justify-center border-b border-black/20 dark:border-white/25 pb-8">
            <img src="/assets/svg/weegschaal.svg" alt="Weegschaal symbool" class="h-44 w-44 object-contain dark:invert" />
          </div>
        </div>
        <div class="hidden lg:block lg:col-span-3"></div>
        <div class="col-span-4 lg:col-span-6">
          <div class="space-y-10">
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Kern</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Weegschaal wordt gedreven door balans, relatie en proportie. Dit teken bekijkt situaties van meerdere kanten en zoekt uitkomsten die eerlijk en werkbaar zijn.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Krachten</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Weegschaal brengt diplomatie, smaak en sociale intelligentie. Het kan spanningen bemiddelen, belangen uitlijnen en interacties vormgeven die kloppen.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Uitdagingen</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">De drang naar harmonie kan besluitvorming vertragen. Weegschaal kan te veel afstemmen op de ander en te weinig op eigen positie. Groei zit in helder kiezen zonder verbinding te verliezen.</p></article>
          </div>
          <p class="mt-12 md:mt-16"><a href="/nl/astrology/" class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]"><span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Terug naar astrologie</a></p>
        </div>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
