---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FooterNL from '../../../components/FooterNL.astro';
---
<BaseLayout
  title="Stier | Astrologie | zomeren.studio"
  description="Stier in astrologie: kernkwaliteiten, krachten, uitdagingen en symbolische betekenis."
  lang="nl"
  enPath="/astrology/taurus/"
  nlPath="/nl/astrology/taurus/"
  ogImage="https://zomeren.studio/assets/images/marco/marco_van_zomeren_studio.webp"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Stier | Astrologie | zomeren.studio","description":"Stier in astrologie: kernkwaliteiten, krachten, uitdagingen en symbolische betekenis.","url":"https://zomeren.studio/nl/astrology/taurus/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/astrology/taurus/" nlHref="/nl/astrology/taurus/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">Stier is een teken van het element Aarde, gevormd door instinct, timing en karakter.</h1>
    </section>
    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <div class="flex aspect-[2/3] w-full items-center justify-center border-b border-black/20 dark:border-white/25 pb-8">
            <img src="/assets/svg/stier.svg" alt="Stier symbool" class="h-44 w-44 object-contain dark:invert" />
          </div>
        </div>
        <div class="hidden lg:block lg:col-span-3"></div>
        <div class="col-span-4 lg:col-span-6">
          <div class="space-y-10">
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Kern</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Stier is gericht op stabiliteit, kwaliteit en tastbare waarde. Dit teken bouwt rustig op, bewaakt wat belangrijk is en kiest voor resultaten die op lange termijn kloppen.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Krachten</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Stier brengt uithoudingsvermogen, kalme focus en nuchter oordeel. Het kan kwetsbare idee&euml;n vertalen naar betrouwbare structuren en veiligheid cre&euml;ren voor mensen en processen.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Uitdagingen</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Onder druk kan Stier te lang vasthouden. Weerstand tegen verandering of comfort kan groei remmen. Ontwikkeling ontstaat wanneer flexibiliteit ook waarde krijgt.</p></article>
          </div>
          <p class="mt-12 md:mt-16"><a href="/nl/astrology/" class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]"><span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Terug naar astrologie</a></p>
        </div>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
