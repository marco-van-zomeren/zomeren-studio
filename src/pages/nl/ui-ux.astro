---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
---
<BaseLayout
  title="UI/UX | zomeren.studio"
  description="Gebruikersgerichte digitale ervaringen gevormd door helderheid, structuur en holistisch denken."
  lang="nl"
  enPath="/ui-ux/"
  nlPath="/nl/ui-ux/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"UI/UX | zomeren.studio","description":"Gebruikersgerichte digitale ervaringen gevormd door helderheid, structuur en holistisch denken.","url":"https://zomeren.studio/nl/ui-ux/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/ui-ux/" nlHref="/nl/ui-ux/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Ik combineer user-centered design met een holistisch perspectief om dit te vertalen naar heldere, coherente interfaces.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img
            src="/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp"
            alt="Ultimo UI/UX visual"
            class="aspect-[2/3] w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(2rem,2.05vw,3rem)] leading-[1.22] tracking-[-0.015em]">
            Ik ontwerp digitale ervaringen die meebewegen met de natuurlijke flow van de gebruiker. In plaats van interfaces te vormen rond trends of algoritmes, bouw ik producten op helderheid, gedrag en momentum. Het is een aanpak geworteld in ritme en structuur, waarbij strategie elke interactie stuurt en elk touchpoint intentioneel aanvoelt. Wanneer de juiste logica de juiste energie ontmoet, wordt de ervaring moeiteloos.
          </p>

          <div class="mt-12 flex flex-wrap items-end gap-6 md:mt-16">
            <a
              href="/nl/website-journey/"
              class="inline-flex w-fit items-center rounded-full bg-black px-6 py-2.5 text-[clamp(1.2rem,1.5vw,2rem)] leading-[1.25] tracking-[-0.012em] text-white dark:bg-white dark:text-black"
            >
              Website traject
            </a>
            <a href="/contact/" class="line-reveal-inline pb-1 text-[clamp(1.2rem,1.5vw,2rem)] tracking-[-0.018em]">
              <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Laten we werken
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
