---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FooterNL from '../../../components/FooterNL.astro';
---
<BaseLayout
  title="Medigo | zomeren.studio"
  description="Medigo website case study by Marco van Zomeren for WADM."
  lang="nl"
  enPath="/projects/medigo/"
  nlPath="/nl/projects/medigo/"
  ogImage="https://zomeren.studio/assets/images/projects/medigo/1_medigo_design-by-wadm.webp"
  bodyClass="project-page"
  schema={`{"@context":"https://schema.org","@type":"CreativeWork","name":"Medigo | zomeren.studio","description":"Medigo website case study by Marco van Zomeren for WADM.","url":"https://zomeren.studio/nl/projects/medigo/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/projects/medigo/" nlHref="/nl/projects/medigo/" lang="nl" />
  <main class="pb-24 md:pb-36">
    <section data-reveal>
      <img src="/assets/images/projects/medigo/1_medigo_design-by-wadm.webp" alt="Medigo cover" class="project-featured-image aspect-[16/9] w-full object-cover" />
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="grid w-full grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-5">
          <h1 class="text-[clamp(2rem,5.4vw,5.2rem)] leading-[0.97] tracking-[-0.02em]">Medigo</h1>
          <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-6 text-[clamp(1rem,1.5vw,2rem)] leading-[1.1] tracking-[-0.01em]">
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">What</p>
            <p>Webdesign</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Where</p>
            <p>WADM</p>
            <p class="uppercase tracking-[0.08em] text-black/75 dark:text-white/75">Role</p>
            <p>Designer</p>
          </div>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em]">
            Medigo wanted a platform that could truly connect healthcare organizations with young medical talent. The ambition was clear: become the place where care institutions and students find each other faster, smarter, and with more confidence. To support that growth, WADM translated Medigo&rsquo;s strategy into a sharper digital story and a website that feels trustworthy for institutions and energetic for students.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="space-y-6 md:space-y-8">
        <video class="aspect-[16/9] w-full object-cover" autoplay muted loop playsinline>
          <source src="https://res.cloudinary.com/zomerenstudio/video/upload/f_mp4/v1771514508/Medigo_ScrollCapture_compilation_i14xds.mp4" type="video/mp4" />
        </video>
      </div>
    </section>

    <section data-reveal class="px-6 pt-16 md:px-12 md:pt-24">
      <div class="space-y-10 md:space-y-12">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Design</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            The design direction balances professionalism and approachability. WADM built a clearer visual identity, refined messaging, and a modular UX system tailored to two audiences: healthcare providers and medical students. Structured layouts, direct calls to action, and a clean interface make the matching process intuitive, while the visual language gives Medigo a stronger, more contemporary presence.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-12">
          <p class="text-[clamp(1.3rem,1.35vw,1.7rem)] uppercase leading-none tracking-[0.04em] lg:col-span-2">Result</p>
          <p class="text-[clamp(1.3rem,2.05vw,2.8rem)] leading-[1.25] tracking-[-0.012em] lg:col-span-8 lg:col-start-5">
            The result is a cohesive digital brand experience that strengthens Medigo&rsquo;s market position and improves usability across the full journey. Institutions can navigate and evaluate faster, students can engage more easily, and the brand now communicates one consistent promise across touchpoints: healthcare and talent, connected with clarity.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pt-14 md:px-12 md:pt-20">
      <div class="space-y-6 md:space-y-8">
        <img src="/assets/images/projects/medigo/2_medigo_design-by-wadm.webp" alt="Medigo image 2" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/3_medigo_design-by-wadm.webp" alt="Medigo image 3" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/4_medigo_design-by-wadm.webp" alt="Medigo image 4" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/5_medigo_design-by-wadm.webp" alt="Medigo image 5" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/6_medigo_design-by-wadm.webp" alt="Medigo image 6" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/7_medigo_design-by-wadm.webp" alt="Medigo image 7" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/8_medigo_design-by-wadm.webp" alt="Medigo image 8" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/9_medigo_design-by-wadm.webp" alt="Medigo image 9" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/10_medigo_design-by-wadm.webp" alt="Medigo image 10" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/11_medigo_design-by-wadm.webp" alt="Medigo image 11" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/12_medigo_design-by-wadm.webp" alt="Medigo image 12" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/13_medigo_design-by-wadm.webp" alt="Medigo image 13" class="w-full object-cover" />
        <img src="/assets/images/projects/medigo/14_medigo_design-by-wadm.webp" alt="Medigo image 14" class="w-full object-cover" />
      </div>
    </section>

    <section data-reveal class="px-6 pt-20 md:px-12 md:pt-24">
      <p class="mb-6 text-[clamp(1.1rem,1vw,1.4rem)] uppercase tracking-[0.08em] text-black/75 dark:text-white/75">More posts</p>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10">
        <article>
          <a href="/nl/projects/mindstone/" class="block">
            <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp" alt="Mindstone cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Mindstone</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
        <article>
          <a href="/nl/projects/ultimo/" class="block">
            <img src="/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp" alt="Ultimo cover" class="aspect-[4/3] w-full object-cover" />
            <div class="mt-5 flex items-end justify-between gap-4">
              <h3 class="text-[clamp(2.1rem,2.8vw,4rem)] leading-none tracking-[-0.02em]">Ultimo</h3>
              <p class="text-[clamp(1rem,1.1vw,1.4rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Webdesign</p>
            </div>
          </a>
        </article>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
