---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
---
<BaseLayout
  title="Holisme | zomeren.studio"
  description="Holistische merkstrategie en astrologisch geinformeerd identiteitswerk door Marco van Zomeren."
  lang="nl"
  enPath="/holism/"
  nlPath="/nl/holism/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Holisme | zomeren.studio","description":"Holistische merkstrategie en astrologisch geinformeerd identiteitswerk door Marco van Zomeren.","url":"https://zomeren.studio/nl/holism/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/holism/" nlHref="/nl/holism/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Binnen een holistische merkstrategie bieden astrologische archetypen een rijk symbolisch kader.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img src="/assets/images/marco/marco_van_zomeren_studio_2.webp" alt="Marco van Zomeren - Holism"
            class="aspect-[2/3] w-full object-cover" loading="eager" decoding="async" />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(2rem,2.05vw,3rem)] leading-[1.22] tracking-[-0.015em]">
            Deze holistische aanpak helpt om de identiteit en designcoherentie van een merk te verdiepen. Door de
            elementaire energie van een merk te verbinden met cognitieve stijl, kunnen designers en strategen
            authentiekere, meer resonerende identiteiten bouwen. Astrologie is &ldquo;een taal van symbolen en archetypen&rdquo; die
            kernpersoonlijkheid weerspiegelt en binnen branding de natuurlijke stijl van een leider zichtbaar maakt,
            sterke kanten en blinde vlekken blootlegt en een visuele/verbale identiteit inspireert die echt klopt.
          </p>

          <div class="mt-10 md:mt-12">
            <h2 class="text-[clamp(2.2rem,3.4vw,4.8rem)] leading-[1.06] tracking-[-0.02em]">Ontdek de Branergy<span
                style="font-size:0.6em; vertical-align:super;">&copy;</span> methode</h2>
            <div class="mt-6">
              <a href="/nl/branergy-methode/"
                class="inline-flex items-center justify-center rounded-full bg-black px-8 py-4 text-[clamp(1.5rem,1.9vw,2.4rem)] leading-none tracking-[-0.01em] text-white transition-colors duration-200 hover:bg-black/85 dark:bg-white dark:text-black dark:hover:bg-white/85 md:px-10 md:py-5">Open
                Methode</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
