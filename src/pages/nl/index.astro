---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
import ShitDoneCtaSection from '../../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="zomeren.studio | Merken laten resoneren met hun hoogste potentieel"
  description="Branding, motion, UI/UX, AI en holistisch design door Marco van Zomeren. Merken laten resoneren met hun hoogste potentieel."
  lang="nl"
  enPath="/"
  nlPath="/nl/"
  ogImage="https://zomeren.studio/assets/images/marco/marco_van_zomeren_studio.webp"
  schema={`{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://zomeren.studio/#organization","name":"zomeren.studio","url":"https://zomeren.studio/","logo":{"@type":"ImageObject","url":"https://zomeren.studio/assets/favicon/android-chrome-512x512.png"},"sameAs":["https://www.youtube.com/@designonacid","https://www.instagram.com/zomeren.studio","https://www.linkedin.com/company/design-on-acid/"]},{"@type":"WebSite","@id":"https://zomeren.studio/#website","url":"https://zomeren.studio/","name":"zomeren.studio","inLanguage":"nl-NL","publisher":{"@id":"https://zomeren.studio/#organization"}},{"@type":"WebPage","@id":"https://zomeren.studio/nl/#webpage","url":"https://zomeren.studio/nl/","name":"zomeren.studio | Merken laten resoneren met hun hoogste potentieel","description":"Branding, motion, UI/UX, AI en holistisch design door Marco van Zomeren. Merken laten resoneren met hun hoogste potentieel.","inLanguage":"nl-NL","isPartOf":{"@id":"https://zomeren.studio/#website"},"about":{"@id":"https://zomeren.studio/#organization"}}]}`}
>
  <Header enHref="/" nlHref="/nl/" lang="nl" />
  <main class="pt-20 md:pt-24">
    <section data-reveal
      class="bg-white dark:bg-black px-6 pb-24 pt-8 text-black dark:text-white md:px-12 md:pb-36 md:pt-12 py-40">
      <div class="grid grid-cols-4 gap-8 intro lg:grid-cols-12">
        <div class="col-span-12 lg:col-span-3">
          <figure>
            <img src="/assets/images/marco/marco_van_zomeren_studio.webp" alt="Portrait of Marco van Zomeren"
              class="aspect-[2/3] w-full object-cover" />
          </figure>
          <p
            class="mt-6 max-w-[30ch] text-[clamp(0.95rem,0.95rem+((1vw-0.2rem)*0.7),1.18rem)] leading-[1.28] tracking-[-0.006em] text-black/95 dark:text-white/95">
            Creatieve hub van <a href="/nl/about/" class="underline underline-offset-4">Marco</a> van Zomeren. Senior
            Brand / Visual Designer bij KR Communicatie, voorheen bij WADM ✦ Bold over well behaved so something beautiful never
            beholds boring.
          </p>
        </div>

        <div class="grid col-span-12 lg:col-span-7 lg:col-start-6">
          <div>
            <h1 class="fade-in-stagger text-[clamp(2em,2rem+((1vw-0.2rem)*4),8rem)] leading-[1.25] tracking-[-0.02em]">
              &#10022; Making brands resonate with their highest potential.
            </h1>
            <h2 class="mt-8 text-[clamp(1.65rem,1.65rem+((1vw-0.2rem)*1.6),2.8rem)] leading-[1.1] tracking-[-0.016em]">
              <span class="text-black/55 dark:text-white/55">Let the sun shine on your</span>
              <span class="words-wrapper">
                <span id="word" class="word text-black dark:text-white">brand</span>
              </span>
            </h2>
          </div>

          <div class="pt-12 pb-8">
            <a href="/contact/"
              class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]">
              <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span>
              Laten we werken
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-4 gap-8 px-6 pb-24 pt-24 md:px-12 md:pb-36 md:pt-36 lg:grid-cols-12 py-40">
      <figure class="header-video col-span-4 lg:col-span-8 lg:col-start-3">
        <video width="1920" height="1080" style="aspect-ratio: 1920 / 1080;" autoplay loop muted playsinline
          src="https://res.cloudinary.com/zomerenstudio/video/upload/v1771511465/zomeren-studio-trail_dtfu4r.mp4"></video>
      </figure>
    </section>

    <section data-reveal class="px-6 pb-24 md:px-12 md:pb-36 py-40">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">01</p>
        </div>

        <div class="relative col-span-4 lg:col-span-8">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">ABOUT</p>

          <p
            class="m-0 max-w-[24ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            Marco is een ontwerper met een holistische benadering, met als kracht het begrijpen, visualiseren en
            vormgeven van kernwaarden.
          </p>
          <a href="/nl/about/"
            class="line-reveal-inline mt-12 pb-1 text-[clamp(1.35rem,2.2vw,2.7rem)] uppercase tracking-[-0.012em]">
            <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> VOLLEDIG VERHAAL
          </a>
        </div>
      </div>
    </section>

    <section data-reveal class="px-6 pb-28 md:px-12 md:pb-40 py-40">
      <div class="relative">
        <p
          class="relative z-20 mb-4 text-right text-[clamp(2.4rem,12vw,14rem)] uppercase leading-[0.84] tracking-[-0.028em] font-[700]">
          &#10022; CREATIVES
        </p>

        <p class="mb-4 text-[clamp(2.4rem,12vw,14rem)] uppercase leading-[0.84] tracking-[-0.028em] font-[700]">ARE THE</p>

        <div data-parallax-wrap class="mt-1 relative grid h-px grid-cols-12 gap-3 md:gap-6">
          <figure data-speed="50"
            class="relative z-20 col-span-7 col-start-1 md:col-span-4 md:col-start-3 will-change-transform">
            <img src="/assets/images/projects/medigo/1_medigo_design-by-wadm.webp" alt="Parallax project visual 1"
              class="aspect-[4/3] w-full object-cover" />
          </figure>

          <figure data-speed="-150"
            class="relative z-20 col-span-7 col-start-6 mt-16 md:col-span-4 md:col-start-8 md:mt-0 will-change-transform">
            <img src="/assets/images/projects/ultimo/6-ultimo-design-by-wadm.webp" alt="Parallax project visual 2"
              class="aspect-[4/3] w-full object-cover" />
          </figure>
        </div>

        <p
          class="mb-4 text-right text-[clamp(2.4rem,12vw,14rem)] uppercase leading-[0.84] tracking-[-0.028em] font-[700]">
          NEW
        </p>
        <p class="text-[clamp(2.4rem,12vw,14rem)] uppercase leading-[0.84] tracking-[-0.028em] font-[700]">CHAMPIONS</p>
      </div>
    </section>

    <section data-reveal class="px-6 pb-28 md:px-12 md:pb-40 py-40">
      <div class="grid grid-cols-4 gap-8 pb-8 md:pb-10 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">02</p>
        </div>

        <div class="relative col-span-4 lg:col-span-6">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">WORK</p>
          <p
            class="m-0 max-w-[24ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            Senior Brand / Visual Designer bij KR Communicatie, voorheen bij WADM.
          </p>
        </div>

        <div class="col-span-4 flex items-start justify-start lg:col-span-4 lg:justify-end">
          <a href="https://krcommunicatie.nl/" target="_blank" rel="noreferrer noopener"
            class="line-reveal-inline pb-1 text-[clamp(1.3rem,1.6vw,2.1rem)] uppercase tracking-[-0.012em]">
            <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.1em;">east</span>
            ONTDEK KR
          </a>
        </div>
      </div>

      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <article class="col-span-4 lg:col-span-8">
          <a href="/nl/projects/mindstone/" class="block">
            <img src="/assets/images/projects/mindstone/mindstone_design_by_wadm_1.webp" alt="Mindstone"
              class="aspect-[5/4] w-full object-cover" />
            <div class="mt-5 flex items-center justify-between gap-4">
              <h3 class="text-[clamp(2rem,2.3vw,3.4rem)] leading-none tracking-[-0.018em]">Mindstone</h3>
              <p class="text-[clamp(1rem,1vw,1.3rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>

        <article class="col-span-4 lg:col-span-4">
          <a href="/nl/projects/gearfreak/" class="block">
            <img src="/assets/images/projects/gearfreak/1_gearfreak_design-by-wadm.webp" alt="Gearfreak"
              class="aspect-[9/16] w-full object-cover" />
            <div class="mt-5 flex items-center justify-between gap-4">
              <h3 class="text-[clamp(2rem,2.3vw,3.4rem)] leading-none tracking-[-0.018em]">Gearfreak</h3>
              <p class="text-[clamp(1rem,1vw,1.3rem)] leading-none tracking-[-0.01em] text-black/75 dark:text-white/75">Branding</p>
            </div>
          </a>
        </article>
      </div>
    </section>

    <section data-reveal
      class="bg-white dark:bg-black px-6 pb-28 pt-12 text-black dark:text-white md:px-12 md:pb-40 py-40">
      <div class="grid grid-cols-4 gap-8 pb-8 md:pb-10 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">03</p>
        </div>

        <div class="relative col-span-4 lg:col-span-6">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">HOLISM</p>
          <p
            class="m-0 max-w-[24ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            I bring structure to chaos, polish to ideas, and intention to every detail.
          </p>
        </div>

        <div class="col-span-4 lg:col-span-4">
          <p class="text-[clamp(1.25rem,2vw,3rem)] leading-[1.24] tracking-[-0.012em] text-black/92 dark:text-white/92">
            My work is sharp, considered, and purpose-driven. But it&rsquo;s my Libra Moon that softens the edges, bringing in
            harmony, beauty, and a deep sensitivity to what feels right. It&rsquo;s not just about design that works. It&rsquo;s
            about design that connects.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-4 gap-8 pb-16 md:pb-24 lg:grid-cols-12">
        <article
          class="col-span-4 border-t border-black/65 dark:border-white/65 py-6 lg:border-l lg:border-t-0 lg:py-0 lg:pl-12">
          <p class="text-[clamp(4.509em,4.509rem+((1vw-0.2em)*8.613),10em)] leading-[0.9] tracking-[-0.02em]">1</p>
          <h3 class="mt-4 text-[clamp(2rem,3.2vw,4.8rem)] leading-[1] tracking-[-0.02em]">Virgo sun</h3>
          <p
            class="mt-4 max-w-[26ch] text-[clamp(1.15rem,1.25vw,2.5rem)] leading-[1.2] tracking-[-0.01em] text-black/92 dark:text-white/92">
            I bring structure to chaos, polish to ideas, and intention to every detail.
          </p>
        </article>

        <article
          class="col-span-4 border-t border-black/65 dark:border-white/65 py-6 lg:border-l lg:border-t-0 lg:py-0 lg:pl-12">
          <p class="text-[clamp(4.509em,4.509rem+((1vw-0.2em)*8.613),10em)] leading-[0.9] tracking-[-0.02em]">2</p>
          <h3 class="mt-4 text-[clamp(2rem,3.2vw,4.8rem)] leading-[1] tracking-[-0.02em]">Libra Moon</h3>
          <p
            class="mt-4 max-w-[26ch] text-[clamp(1.15rem,1.25vw,2.5rem)] leading-[1.2] tracking-[-0.01em] text-black/92 dark:text-white/92">
            Bringing in harmony, beauty, and a deep sensitivity to what feels right.
          </p>
        </article>

        <article
          class="col-span-4 border-t border-black/65 dark:border-white/65 py-6 lg:border-l lg:border-t-0 lg:py-0 lg:pl-12">
          <p class="text-[clamp(4.509em,4.509rem+((1vw-0.2em)*8.613),10em)] leading-[0.9] tracking-[-0.02em]">3</p>
          <h3 class="mt-4 text-[clamp(2rem,3.2vw,4.8rem)] leading-[1] tracking-[-0.02em]">Leo Rising</h3>
          <p
            class="mt-4 max-w-[26ch] text-[clamp(1.15rem,1.25vw,2.5rem)] leading-[1.2] tracking-[-0.01em] text-black/92 dark:text-white/92">
            I carry it all with confidence and creative direction.
          </p>
        </article>
      </div>

      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-4">
          <img src="/assets/images/mockup_holism-design-1024x683.webp" alt="Holism Design mockup"
            class="aspect-[2/3] w-full object-cover" />
        </div>

        <div class="col-span-4 grid lg:col-span-7 lg:col-start-6">
          <p class="mb-16 text-[clamp(4.16em,4.16rem_+_((1vw_-_0.2em)_*_7.592),15em)] leading-[1] tracking-[-0.025em]">
            Holism
            Design</p>

          <div class="flex flex-wrap items-end gap-5">
            <a href="/nl/branergy-methode/"
              class="inline-flex w-fit items-center rounded-full bg-black px-6 py-2.5 text-[clamp(1.2rem,1.5vw,2rem)] leading-[1.25] tracking-[-0.012em] text-white dark:bg-white dark:text-black">
              Lees manifest
            </a>
            <a href="/nl/about/"
              class="line-reveal-inline w-fit pb-1 text-[clamp(1.2rem,1.5vw,2rem)] tracking-[-0.012em]">
              <span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.1em;">east</span>
              Boek als spreker
            </a>
          </div>
        </div>
      </div>
    </section>

    <section data-reveal class="bg-white dark:bg-black px-6 pb-24 text-black dark:text-white md:px-12 md:pb-36 py-40">
      <div class="grid grid-cols-4 gap-8 pb-12 md:pb-16 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">04</p>
        </div>

        <div class="relative col-span-4 lg:col-span-8">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">SKILLS</p>
          <p
            class="m-0 max-w-[24ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            Expertises die merken laten resoneren met hun hoogste potentieel
          </p>
        </div>
      </div>

      <div class="space-y-5 md:space-y-6">
        <a href="/nl/branding/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">01</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">Branding</span>
        </a>
        <a href="/nl/motion/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">02</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">Motion</span>
        </a>
        <a href="/nl/ui-ux/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">03</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">UI/UX</span>
        </a>
        <a href="/nl/ai/" class="line-reveal-link pb-4 md:pb-5">
          <span class="col-span-3 text-[clamp(1.1rem,1.9vw,2rem)] leading-none tracking-[-0.01em] md:col-span-2">04</span>
          <span class="col-span-9 text-[clamp(2rem,5.1vw,6rem)] leading-[0.95] tracking-[-0.02em] md:col-span-10">AI</span>
        </a>
      </div>
    </section>

    <section data-reveal class="px-6 pb-28 md:px-12 md:pb-40 py-40">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-2">
          <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">04</p>
        </div>

        <div class="relative col-span-4 lg:col-span-10">
          <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">FAQ</p>
          <p
            class="m-0 max-w-[23ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
            Goede vragen verdienen doordachte antwoorden, dit zijn de vragen die ik het vaakst krijg.
          </p>

          <div class="mt-16 space-y-0 md:mt-20">
            <details class="faq-item group border-b border-black/35 dark:border-white/35">
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 text-[clamp(1.5rem,3vw,3.35rem)] leading-[1.05] tracking-[-0.014em] [&::-webkit-details-marker]:hidden">
                <span>Wat kost een project?</span>
                <span class="faq-plus material-symbols-outlined text-[1.05em]">add_2</span>
              </summary>
              <div class="faq-answer">
                <div class="faq-answer-inner">
                  <p
                    class="max-w-3xl pb-6 text-[clamp(1rem,1.2vw,1.35rem)] leading-[1.58] tracking-[0.002em] text-black/82 dark:text-white/82">
                    Budgets depend on scope, timeline, and complexity. Most projects start with a clear proposal after a
                    short discovery call.
                  </p>
                </div>
              </div>
            </details>

            <details class="faq-item group border-b border-black/35 dark:border-white/35">
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 text-[clamp(1.5rem,3vw,3.35rem)] leading-[1.05] tracking-[-0.014em] [&::-webkit-details-marker]:hidden">
                <span>Welke diensten bied je aan?</span>
                <span class="faq-plus material-symbols-outlined text-[1.05em]">add_2</span>
              </summary>
              <div class="faq-answer">
                <div class="faq-answer-inner">
                  <p
                    class="max-w-3xl pb-6 text-[clamp(1rem,1.2vw,1.35rem)] leading-[1.58] tracking-[0.002em] text-black/82 dark:text-white/82">
                    I work across brand identity, digital design, motion direction, and design systems for teams that
                    need clarity and consistency.
                  </p>
                </div>
              </div>
            </details>

            <details class="faq-item group border-b border-black/35 dark:border-white/35">
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 text-[clamp(1.5rem,3vw,3.35rem)] leading-[1.05] tracking-[-0.014em] [&::-webkit-details-marker]:hidden">
                <span>Hoe werk je?</span>
                <span class="faq-plus material-symbols-outlined text-[1.05em]">add_2</span>
              </summary>
              <div class="faq-answer">
                <div class="faq-answer-inner">
                  <p
                    class="max-w-3xl pb-6 text-[clamp(1rem,1.2vw,1.35rem)] leading-[1.58] tracking-[0.002em] text-black/82 dark:text-white/82">
                    Every project runs through research, concept, and execution phases with regular checkpoints, so
                    decisions stay fast and aligned.
                  </p>
                </div>
              </div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <section data-reveal class="pb-32 md:pb-44 py-40">
      <div class="px-6 md:px-12">
        <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
          <div class="col-span-4 lg:col-span-2">
            <p class="mt-[0.75em] text-[clamp(1.2rem,1.8vw,1.9rem)] leading-none tracking-[-0.01em]">05</p>
          </div>

          <div class="relative col-span-4 lg:col-span-10">
            <p class="absolute left-0 top-1 text-[clamp(0.85rem,0.95vw,1rem)] uppercase tracking-[0.08em]">REVIEWS</p>
            <p
              class="m-0 max-w-[23ch] text-[clamp(2rem,3vw,6rem)] font-semibold leading-[1.08] tracking-[-0.02em] [text-indent:clamp(4rem,12vw,15rem)]">
              15 years in the game, 100+ brands transformed and countless stories that still move on.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-16 md:mt-20">
        <div class="swiper reviews-swiper">
          <div class="swiper-wrapper">
            <article class="swiper-slide flex h-auto flex-col border border-black/35 p-8 dark:border-white/35 md:p-10">
              <p class="text-[clamp(1.05rem,1.45vw,1.85rem)] leading-[1.25] tracking-[-0.01em]">
                Marco vertaalde onze propositie naar een visuele identiteit die helder, betrouwbaar en premium aanvoelt.
                De nieuwe richting bracht rust en consistentie in al onze communicatie.
