---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
import ShitDoneCtaSection from '../../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="ACID Methode | zomeren.studio"
  description="De ACID Methode is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig uit te drukken."
  lang="nl"
  enPath="/acid-method/"
  nlPath="/nl/acid-methode/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"ACID Methode | zomeren.studio","description":"De ACID Methode is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig uit te drukken.","url":"https://zomeren.studio/nl/acid-methode/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/acid-method/" nlHref="/nl/acid-methode/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        De ACID Methode<span style="font-size:0.6em; vertical-align:super;">&copy;</span> is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig tot uitdrukking te brengen.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img
            src="/assets/images/marco/marco_van_zomeren_studio_4.webp"
            alt="Portret van Marco van Zomeren"
            class="aspect-[2/3] w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            Het is een aanpak die begint bij de mens achter het merk en alles bekijkt door de lens van astrologie: de archetypes lucht, water, aarde en vuur. Vanuit die inzichten vertalen we naar identiteitssystemen die van nature kloppen.
          </p>
          <p class="mt-6 text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            De ACID Methode volgt de natuurlijke synergie tussen de vier astrologische elementen lucht, water, aarde en vuur en gebruikt die als thematische richting voor de vier fases van een merkreis. Elk element vertegenwoordigt een unieke energie die samen het complete merkverhaal vormt, van fundament tot expressie.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="py-8 md:py-12">
      <div class="space-y-12 md:space-y-16">
        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/air.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">A — Abstraction (Lucht)</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Ideeën, perceptie, conceptuele kaders</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Perceptie & cognitie. Lucht scheidt, analyseert, observeert patronen en creëert mentale afstand.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/water.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">C — Connection (Water)</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Emotie, empathie, relationele stroom</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Emotie & relationele stroom. Water verbindt, past aan, voelt in en verbindt.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/earth.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">I — Intention (Aarde)</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Systemen, structuur, samenhang</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Structuur & stabiliteit. Aarde aardt, beschermt, plant en creëert veiligheid.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/fire.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">D — Disruption (Vuur)</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Actie, verandering, patronen doorbreken</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Actie & transformatie. Vuur verandert, activeert en vernietigt stagnatie.
            </p>
          </div>
        </article>
      </div>
    </section>

    <ShitDoneCtaSection />
  </main>
  <FooterNL />
</BaseLayout>
