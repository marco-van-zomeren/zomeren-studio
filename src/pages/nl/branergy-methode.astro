---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
import ShitDoneCtaSection from '../../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="Branergy Methode | zomeren.studio"
  description="Branergy is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig uit te drukken."
  lang="nl"
  enPath="/branergy-method/"
  nlPath="/nl/branergy-methode/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Branergy Methode | zomeren.studio","description":"Branergy is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig uit te drukken.","url":"https://zomeren.studio/nl/branergy-methode/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/branergy-method/" nlHref="/nl/branergy-methode/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Branergy<span style="font-size:0.6em; vertical-align:super;">&copy;</span> is een holistische methode die merken helpt hun ware potentieel te ontdekken en volledig tot uitdrukking te brengen.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img
            src="/assets/images/marco/marco_van_zomeren_studio_4.webp"
            alt="Portret van Marco van Zomeren"
            class="aspect-[2/3] w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            Het is een aanpak die begint bij de mens achter het merk en alles bekijkt door de lens van astrologie: de archetypes aarde, vuur, lucht en water. Vanuit die inzichten vertalen we naar identiteitssystemen die van nature kloppen.
          </p>
          <p class="mt-6 text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            De Branergy Methode volgt de natuurlijke synergie tussen de vier astrologische elementen aarde, water, lucht en vuur en gebruikt die als thematische richting voor de vier fases van een Branergy-reis. Elk element vertegenwoordigt een unieke energie die samen het complete merkverhaal vormt, van fundament tot expressie.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="py-8 md:py-12">
      <div class="space-y-12 md:space-y-16">
        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/earth.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">1 Aarde</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Stabiliteit, structuur en realisatie</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Een sterk merk begint met een solide basis. In deze fase onderzoeken we wie je bent, waar je voor staat en wat je onderscheidt. We leggen de basis voor groei door de essentie van het merk te verankeren in heldere waarden en richting.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/water.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">2 Water</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Emotie, intu&iuml;tie en verbinding</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Vanuit die basis cre&euml;ren we beweging. In de waterfase vertalen we inzichten naar een merkstrategie die de levenslijn van het merk wordt en alle zintuigen verbindt: van onderbuikgevoel tot intellect, menselijk en intu&iuml;tief. We bouwen een verhaal dat resoneert met klanten en het merk natuurlijk laat stromen tussen mens en markt.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/air.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">3 Lucht</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Denken, communicatie en concept</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Lucht staat voor helderheid en perspectief. Hier scherpen we de visie aan en vertalen die naar een krachtige manier van communiceren. We bepalen de tone of voice, vormen de merkboodschap en zorgen dat je verhaal moeiteloos door elke uiting beweegt.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/fire.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">4 Vuur</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Actie, creatie en inspiratie</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Hier komt alles samen. De strategie krijgt vorm en het verhaal krijgt een gezicht. We vertalen de energie van het merk naar design: visueel, tastbaar en vol karakter. Dit is waar het merk in zijn kracht komt te staan en zijn ware potentieel gaat belichamen en uitdragen.
            </p>
          </div>
        </article>
      </div>
    </section>

    <ShitDoneCtaSection />
  </main>
  <FooterNL />
</BaseLayout>
