---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FooterNL from '../../../components/FooterNL.astro';
import { client, urlFor } from '../../../lib/sanity';

const posts = await client.fetch(`
  *[_type == "post"] | order(publishedAt desc) {
    title, slug, description, publishedAt, tags, headerImage
  }
`);
---
<BaseLayout
  title="Blog | zomeren.studio"
  description="Gedachten over design, branding, holisme en het creatieve proces van Marco van Zomeren."
  lang="nl"
  enPath="/blog/"
  nlPath="/nl/blog/"
>
  <Header enHref="/blog/" nlHref="/nl/blog/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="max-w-[24ch] text-[clamp(2.4rem,5vw,7rem)] leading-[1.02] tracking-[-0.024em] font-[700]">
        Gedachten over design, brand&shy;ing en holisme.
      </h1>
    </section>
    <section data-reveal class="pt-10 md:pt-14">
      {posts.length === 0 ? (
        <p class="text-[clamp(1.8rem,1.6vw,2.6rem)] leading-[1.1] tracking-[-0.012em] text-black/50 dark:text-white/50">Nog geen berichten.</p>
      ) : (
        <ul class="divide-y divide-black/10 dark:divide-white/10">
          {posts.map((post: any) => (
            <li class="py-10 md:py-12">
              <a href={`/nl/blog/${post.slug.current}/`} class="group block md:grid md:grid-cols-[1fr_auto] md:gap-12 md:items-start">
                <div>
                  <p class="text-[clamp(1.4rem,1.2vw,2rem)] tracking-[-0.01em] text-black/50 dark:text-white/50">
                    {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
                  </p>
                  <h2 class="mt-3 text-[clamp(2rem,3vw,4.5rem)] leading-[1.05] tracking-[-0.02em] font-[600] group-hover:opacity-70 transition-opacity">{post.title}</h2>
                  {post.description && (
                    <p class="mt-3 max-w-[55ch] text-[clamp(1.6rem,1.5vw,2.4rem)] leading-[1.3] tracking-[-0.012em] text-black/70 dark:text-white/70">{post.description}</p>
                  )}
                  {post.tags && post.tags.length > 0 && (
                    <ul class="mt-4 flex gap-2 flex-wrap">
                      {post.tags.map((tag: string) => (
                        <li class="text-[clamp(1.3rem,1vw,1.7rem)] tracking-[-0.01em] bg-black/5 dark:bg-white/10 px-3 py-1 rounded-full">{tag}</li>
                      ))}
                    </ul>
                  )}
                </div>
                {post.headerImage ? (
                  <img
                    src={urlFor(post.headerImage).width(400).height(300).fit('crop').url()}
                    alt={post.headerImage.alt ?? post.title}
                    class="mt-6 md:mt-0 w-full md:w-[22rem] aspect-[4/3] object-cover"
                  />
                ) : (
                  <div class="mt-6 md:mt-0 w-full md:w-[22rem] aspect-[4/3] bg-black/5 dark:bg-white/5" />
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
  <FooterNL />
</BaseLayout>
