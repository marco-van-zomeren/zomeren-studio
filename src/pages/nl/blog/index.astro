---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FooterNL from '../../../components/FooterNL.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---
<BaseLayout
  title="Blog | zomeren.studio"
  description="Gedachten over design, branding, holisme en het creatieve proces van Marco van Zomeren."
  lang="nl"
  enPath="/blog/"
  nlPath="/nl/blog/"
>
  <Header enHref="/blog/" nlHref="/nl/blog/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="max-w-[24ch] text-[clamp(2.4rem,5vw,7rem)] leading-[1.02] tracking-[-0.024em] font-[700]">
        Gedachten over design, brand&shy;ing en holisme.
      </h1>
    </section>
    <section data-reveal class="pt-10 md:pt-14">
      <ul class="divide-y divide-black/10 dark:divide-white/10">
        {posts.map((post) => (
          <li class="py-10 md:py-12">
            <a href={`/nl/blog/${post.id}/`} class="group block">
              <p class="text-[clamp(1.4rem,1.2vw,2rem)] tracking-[-0.01em] text-black/50 dark:text-white/50">{post.data.pubDate}</p>
              <h2 class="mt-3 text-[clamp(2rem,3vw,4.5rem)] leading-[1.05] tracking-[-0.02em] font-[600] group-hover:opacity-70 transition-opacity">{post.data.title}</h2>
              <p class="mt-3 max-w-[55ch] text-[clamp(1.6rem,1.5vw,2.4rem)] leading-[1.3] tracking-[-0.012em] text-black/70 dark:text-white/70">{post.data.description}</p>
              {post.data.tags && (
                <ul class="mt-4 flex gap-2 flex-wrap">
                  {post.data.tags.map((tag) => (
                    <li class="text-[clamp(1.3rem,1vw,1.7rem)] tracking-[-0.01em] bg-black/5 dark:bg-white/10 px-3 py-1 rounded-full">{tag}</li>
                  ))}
                </ul>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <FooterNL />
</BaseLayout>
