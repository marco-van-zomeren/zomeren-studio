---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FooterNL from '../../components/FooterNL.astro';
import ShitDoneCtaSection from '../../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="Website Traject | zomeren.studio"
  description="Een website-traject in vier fasen: discovery, wireframes, visueel design, motion en uiteindelijke handoff."
  lang="nl"
  enPath="/website-journey/"
  nlPath="/nl/website-journey/"
  ogImage="https://zomeren.studio/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Website Traject | zomeren.studio","description":"Een website-traject in vier fasen: discovery, wireframes, visueel design, motion en uiteindelijke handoff.","url":"https://zomeren.studio/nl/website-journey/","inLanguage":"nl-NL","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/website-journey/" nlHref="/nl/website-journey/" lang="nl" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Een website-traject waarbij strategie, design en oplevering vloeiend in elkaar overlopen.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img src="/assets/images/projects/ultimo/1-ultimo-design-by-wadm.webp" alt="Visual van een website-traject"
            class="aspect-[2/3] w-full object-cover" loading="eager" decoding="async" />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            Een sterk websiteproject begint lang voordat er pixels bewegen. Het start met begrijpen wat de vraag is,
            hoe de markt eruitziet, wie de concurrenten zijn, hoeveel pagina&rsquo;s nodig zijn, wat de technische realiteit is,
            en welke scope klopt om het werk echt bruikbaar te maken.
          </p>
          <p class="mt-6 text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            Dit website-traject volgt vier praktische fasen: aarde, lucht, vuur en water. Elke fase brengt het proces
            verder met een ander doel, van discovery en wireframes tot visueel design, motion, feedback en de uiteindelijke oplevering.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="py-8 md:py-12">
      <div class="space-y-12 md:space-y-16">
        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/earth.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">1 Structuur</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Discovery, scope en fundament</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              We starten met een werksessie om de vraag volledig te begrijpen: bedrijfsdoelen, doelgroep, markt,
              concurrenten, contentbehoefte, hoeveelheid pagina&rsquo;s, planning en technische context. In deze fase zetten we
              de scope scherp en leggen we de structuur vast die nodig is om later met helderheid te beslissen.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/air.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">2 Strategie</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Concept, sitemap en wireframes</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Zodra het fundament staat, bouwen we het eerste concept. Dat betekent meestal een sitemap, contenthiërarchie,
              wireframes en een eerste visuele richting voor de site. Het is de fase waarin logica en gevoel samenkomen,
              en waarin de eerste feedbackronde de route aanscherpt voordat het design verder wordt doorgetrokken.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/fire.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">3 Visie</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Visueel design, motion en interactie</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Hier krijgt de website zijn visuele kracht. We ontwerpen de belangrijkste templates en pagina&rsquo;s in detail,
              defini&euml;ren componenten, interactiestates en motion-principes, en onderzoeken hoe transities en animaties ritme
              kunnen toevoegen zonder de usability te verstoren. Dit is het moment waarop het concept echt gaat leven.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/water.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">4 Oplevering</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Presentatie, verfijning en handoff</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              De laatste fase draait om afstemming en oplevering. We presenteren het complete visuele design, lopen door de
              ervaring heen, bespreken impact en gevoel, verwerken de laatste feedbackronde en bereiden de handoff voor.
              Deliverables kunnen bestaan uit designbestanden, een style guide, motion-referenties en alle assets die nodig zijn voor development.
            </p>
          </div>
        </article>
      </div>
    </section>

    <ShitDoneCtaSection />
  </main>
  <FooterNL />
</BaseLayout>
