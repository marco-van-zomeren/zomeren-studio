---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ShitDoneCtaSection from '../components/ShitDoneCtaSection.astro';
---
<BaseLayout
  title="Branergy Method | zomeren.studio"
  description="The Branergy method: a holistic brand strategy framework using astrological elements as creative compass."
  lang="en"
  enPath="/branergy-method/"
  nlPath="/nl/branergy-method/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Branergy Method | zomeren.studio","description":"The Branergy method: a holistic brand strategy framework using astrological elements as creative compass.","url":"https://zomeren.studio/branergy-method/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/branergy-method/" nlHref="/nl/branergy-method/" lang="en" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">
        Branergy<span style="font-size:0.6em; vertical-align:super;">&copy;</span> is a holistic method that helps
        brands discover their true potential and express it fully.
      </h1>
    </section>

    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <img src="/assets/images/marco/marco_van_zomeren_studio_4.webp" alt="Marco van Zomeren portrait"
            class="aspect-[2/3] w-full object-cover" loading="eager" decoding="async" />
        </div>

        <div class="hidden lg:block lg:col-span-3"></div>

        <div class="col-span-4 lg:col-span-6">
          <p class="text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            It's an approach that starts with the human behind the brand and views everything through the lens of
            astrology: the earth, fire, air and water archetypes. We can then translate insights into identity systems
            that feel naturally aligned.
          </p>
          <p class="mt-6 text-[clamp(1.4rem,2vw,2.7rem)] leading-[1.24] tracking-[-0.012em]">
            The Branergy Method follows the natural synergy between the four astrological elements earth, water, air,
            and fire and uses them as thematic cues for the four phases of a Branergy journey. Each element represents
            a unique energy that, together, shapes the complete story of a brand, from foundation to expression.
          </p>
        </div>
      </div>
    </section>

    <section data-reveal class="py-8 md:py-12">
      <div class="space-y-12 md:space-y-16">
        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/earth.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">1 Earth</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Stability, structure, and realization</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              A strong brand begins with a solid foundation. In this phase, we explore who you are, what you stand for,
              and what sets you apart. We establish the groundwork for growth by anchoring the brand's essence in clear
              values and direction.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/water.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">2 Water</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Emotion, intuition, and connection</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              From that foundation, we create movement. In the water phase, we translate insights into a brand strategy
              that becomes the brand's lifeline and connects all senses, from gut feeling to intellect, human and
              intuitive. We craft a story that resonates with customers and allows the brand to flow naturally between
              people and market.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/air.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">3 Air</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Thinking, communication, and concept</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              Air represents clarity and perspective. Here, we sharpen the vision and translate it into a powerful way
              of communicating. We define the tone of voice, shape the brand message, and ensure your story moves
              effortlessly through every expression.
            </p>
          </div>
        </article>

        <article class="grid grid-cols-4 gap-8 border-b border-black/40 dark:border-white/40 pb-10 md:pb-12 lg:grid-cols-12">
          <div class="col-span-1 lg:col-span-2">
            <img src="/assets/svg/fire.svg" alt="" class="h-20 w-20 object-contain brightness-0 dark:invert" aria-hidden="true" />
          </div>
          <div class="col-span-3 lg:col-span-8">
            <h2 class="text-[clamp(2.2rem,3.7vw,5rem)] leading-none tracking-[-0.02em]">4 Fire</h2>
            <p class="mt-3 text-[clamp(1.3rem,1.9vw,2.5rem)] leading-[1.2] tracking-[-0.01em]">Action, creation, and inspiration</p>
            <p class="mt-4 text-[clamp(1.05rem,1.3vw,1.9rem)] leading-[1.3] tracking-[-0.01em] text-black/92 dark:text-white/92">
              This is where everything comes together. The strategy takes shape, and the story gains a face. We
              translate the brand's energy into design: visual, tangible, and full of character. This is where the brand
              stands in its power and begins to embody and express its true potential.
            </p>
          </div>
        </article>
      </div>
    </section>

    <ShitDoneCtaSection />
  </main>
  <Footer />
</BaseLayout>
