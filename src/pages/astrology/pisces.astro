---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Pisces | Astrology | zomeren.studio"
  description="Pisces in astrology: core traits, strengths, challenges and symbolic meaning."
  lang="en"
  enPath="/astrology/pisces/"
  nlPath="/nl/astrology/pisces/"
  schema={`{"@context":"https://schema.org","@type":"WebPage","name":"Pisces | Astrology | zomeren.studio","description":"Pisces in astrology: core traits, strengths, challenges and symbolic meaning.","url":"https://zomeren.studio/astrology/pisces/","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"zomeren.studio","url":"https://zomeren.studio/"}}`}
>
  <Header enHref="/astrology/pisces/" nlHref="/nl/astrology/pisces/" lang="en" />
  <main class="px-6 pb-24 pt-20 md:px-12 md:pb-36 md:pt-24">
    <section data-reveal class="py-10 md:py-16">
      <h1 class="fade-in-stagger m-0 text-[clamp(2.4rem,5vw,7rem)] leading-[1.08] tracking-[-0.022em]">Pisces is a Water sign shaped by instinct, timing and character.</h1>
    </section>
    <section data-reveal class="py-10 md:py-14">
      <div class="grid grid-cols-4 gap-8 lg:grid-cols-12">
        <div class="col-span-4 lg:col-span-3">
          <div class="flex aspect-[2/3] w-full items-center justify-center border-b border-black/20 dark:border-white/25 pb-8">
            <img src="/assets/svg/vissen.svg" alt="Pisces symbol" class="h-44 w-44 object-contain dark:invert" />
          </div>
        </div>
        <div class="hidden lg:block lg:col-span-3"></div>
        <div class="col-span-4 lg:col-span-6">
          <div class="space-y-10">
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Core</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Pisces experiences life through sensitivity, imagination, and symbolic awareness. It perceives subtle layers beneath the obvious and navigates through intuition as much as logic.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Strengths</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Pisces contributes empathy, creativity, and spiritual depth. It can translate emotion into art, support healing processes, and sense possibilities that structured thinking can miss.</p></article>
            <article><h2 class="text-[clamp(1.7rem,2.2vw,2.8rem)] leading-[1.12] tracking-[-0.02em]">Challenges</h2><p class="mt-4 text-[clamp(1.2rem,1.55vw,2rem)] leading-[1.3] tracking-[-0.012em]">Open boundaries can lead to overwhelm or escapism. Pisces grows by pairing compassion with containment, and intuition with grounded routines.</p></article>
          </div>
          <p class="mt-12 md:mt-16"><a href="/astrology/" class="line-reveal-inline pb-1 text-[clamp(1.9rem,2.2vw,2.8rem)] tracking-[-0.018em]"><span class="material-symbols-outlined" style="font-size:1em;position:relative;top:0.15em;">east</span> Back to astrology</a></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
