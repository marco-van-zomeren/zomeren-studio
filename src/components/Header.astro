---
interface Props {
  enHref: string;
  nlHref: string;
  lang?: 'en' | 'nl';
}

const { enHref, nlHref, lang = 'en' } = Astro.props;

const isNL = lang === 'nl';
const homeHref = isNL ? '/nl/' : '/';
const designHref = isNL ? '/nl/design/' : '/design/';
const workHref = isNL ? '/nl/work/' : '/work/';
const aboutHref = isNL ? '/nl/about/' : '/about/';
const holismHref = isNL ? '/nl/holism/' : '/holism/';

const labelDesign = isNL ? 'Ontwerp' : 'Design';
const labelWork = isNL ? 'Werk' : 'Work';
const labelAbout = isNL ? 'Over' : 'About';
const labelHolism = isNL ? 'Holisme' : 'Holism';
---

<header class="fixed inset-x-0 top-0 z-[70] px-6 py-7 text-black dark:text-white md:text-white md:mix-blend-difference md:px-12 md:py-8">
  <div class="relative flex w-full items-center justify-between">
    <input id="menu-toggle" type="checkbox" class="peer sr-only" />
    <a href={homeHref} class="text-[clamp(1.9rem,5vw,2.2rem)] leading-none md:hidden">zomeren.studio</a>
    <label
      for="menu-toggle"
      aria-label="Toggle menu"
      class="relative z-50 flex h-10 w-10 cursor-pointer items-center justify-center md:hidden
      before:content-[''] before:absolute before:left-1/2 before:top-1/2 before:block before:h-px before:w-6 before:-translate-x-1/2 before:-translate-y-[4px]
      before:bg-current before:transition-transform before:duration-300 before:ease-in-out
      after:content-[''] after:absolute after:left-1/2 after:top-1/2 after:block after:h-px after:w-6 after:-translate-x-1/2 after:translate-y-[4px]
      after:bg-current after:transition-transform after:duration-300 after:ease-in-out
      peer-checked:before:translate-y-0 peer-checked:before:rotate-45
      peer-checked:after:translate-y-0 peer-checked:after:-rotate-45"
    ></label>

    <nav aria-label="Primary" class="hidden w-full grid-cols-5 items-center text-[clamp(1.95rem,1.95vw,3.4rem)] leading-none tracking-[-0.016em] md:grid">
      <a href={designHref} class="justify-self-start">{labelDesign}</a>
      <a href={workHref} class="justify-self-start">{labelWork}</a>
      <a href={homeHref} class="justify-self-center">zomeren.studio</a>
      <a href={aboutHref} class="justify-self-end">{labelAbout}</a>
      <div class="justify-self-end flex items-end gap-4">
        <a href={holismHref}>{labelHolism}</a>
        <span class="text-[clamp(1.05rem,1vw,1.35rem)] leading-none tracking-[-0.01em]">
          {isNL
            ? <><a href={enHref} class="opacity-75">EN</a> / <a href={nlHref} class="opacity-100">NL</a></>
            : <><a href={enHref} class="opacity-100">EN</a> / <a href={nlHref} class="opacity-75">NL</a></>
          }
        </span>
      </div>
    </nav>

    <div class="pointer-events-none fixed inset-0 z-40 h-screen w-screen bg-white dark:bg-black px-6 pb-10 pt-28 opacity-0 transition-opacity duration-300 ease-in-out peer-checked:pointer-events-auto peer-checked:opacity-100 md:hidden mix-blend-normal">
      <nav aria-label="Mobile Primary" class="flex flex-col gap-6 text-[clamp(1.3rem,8vw,2.5rem)] leading-[1.05] tracking-[-0.012em] text-black dark:text-white">
        <a href={designHref}>{labelDesign}</a>
        <a href={workHref}>{labelWork}</a>
        <a href={aboutHref}>{labelAbout}</a>
        <a href={holismHref}>{labelHolism}</a>
        <p class="text-[clamp(1rem,4.8vw,1.5rem)] leading-none tracking-[-0.01em]">
          {isNL
            ? <><a href={enHref} class="opacity-75">EN</a> / <a href={nlHref}>NL</a></>
            : <><a href={enHref}>EN</a> / <a href={nlHref} class="opacity-75">NL</a></>
          }
        </p>
      </nav>
    </div>
  </div>
</header>
